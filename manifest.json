{
    "manifest_version": 3,
    "name": "MarketLens",
    "version": "1.0",
    "description": "AI-powered trading assistant that watches live TradingView charts and delivers real-time buy/sell signals using vision AI",
    "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
],
    "host_permissions": [
    "https://www.tradingview.com/*",
    "https://api.anthropic.com/*"
],
    "content_scripts": [
      {
        "matches": ["https://www.tradingview.com/*"],
        "js": ["src/content.js"]
      }
    ],
    "action": {
      "default_popup": "src/popup.html",
      "default_title": "MarketLens"
    },
    "options_page": "src/options.html",
    "background": {
      "service_worker": "src/background.js"
    }
  }